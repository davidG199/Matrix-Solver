---
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";
import operations from "../data/operations.json";

const backendBaseUrl = import.meta.env.PUBLIC_API_URL;

const initialOperation = operations[0];
---

<Layout title="Matrix Solver | Algebra Lineal">
  <aside
    slot="aside"
    id="mobile-operation-aside"
    data-mobile-aside
    class="fixed inset-y-0 left-0 z-40 flex h-dvh w-[min(86vw,20rem)] -translate-x-full flex-col gap-6 overflow-y-auto border-r border-white/10 bg-slate-950/95 px-4 py-6 backdrop-blur-2xl transition-transform duration-300 lg:sticky lg:top-0 lg:z-auto lg:w-auto lg:translate-x-0 lg:border-b-0 lg:bg-slate-950/45"
  >
    <div
      class="flex items-center gap-3 justify-center border-b pb-4 border-white/20"
    >
      <p class="display-font text-lg font-bold tracking-tighter text-white">
        Matrix Solver
      </p>
    </div>

    <div class="grid gap-2">
      {
        operations.map((operation, index) => (
          <button
            type="button"
            data-operation-button
            data-operation-key={operation.key}
            class={`cursor-pointer flex items-start justify-between  border px-4 py-3 transition duration-200  ${index === 0 ? " text-white shadow-[0_12px_30px_rgba(0,0,0,0.2)]" : "border-white/10 bg-white/5 text-slate-300 hover:border-white/20 hover:bg-white/10"}`}
            aria-pressed={index === 0 ? "true" : "false"}
          >
            <span>
              <strong class="block text-sm font-semibold">
                {operation.label}
              </strong>
            </span>
          </button>
        ))
      }
    </div>
  </aside>

  <main
    slot="main"
    class="relative min-h-screen overflow-hidden px-4 py-5 sm:px-6 lg:px-10 lg:py-10"
  >
    <div
      data-mobile-overlay
      class="pointer-events-none fixed inset-0 z-30 bg-slate-950/70 opacity-0 transition-opacity duration-300 lg:hidden"
      aria-hidden="true"
    ></div>

    <div
      class="absolute inset-0 bg-[radial-gradient(circle_at_14%_12%,rgba(56,189,248,0.16),transparent_24%),radial-gradient(circle_at_85%_8%,rgba(99,102,241,0.2),transparent_26%),radial-gradient(circle_at_50%_100%,rgba(16,185,129,0.14),transparent_28%)]"
    >
    </div>

    <div
      class="absolute inset-0 bg-[linear-gradient(180deg,rgba(5,8,16,0.62),rgba(5,8,16,0.24)_42%,rgba(5,8,16,0.72))]"
    >
    </div>

    <div class="relative mx-auto flex max-w-7xl flex-col gap-6">
      <section class="p-6">
        <div class="mb-4 flex lg:hidden">
          <button
            type="button"
            data-mobile-menu-button
            aria-controls="mobile-operation-aside"
            aria-expanded="false"
            class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm font-semibold text-white transition hover:border-white/20 hover:bg-white/10"
          >
            <span class="text-base">☰</span>
            Menú de operaciones
          </button>
        </div>
        <div
          class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between"
        >
          <div class="max-w-4xl">
            <h1
              data-operation-title
              class="display-font mt-2 text-4xl font-bold tracking-tighter text-white sm:text-5xl"
            >
              {initialOperation.title}
            </h1>
            <p
              data-operation-description
              class="mt-3 max-w-3xl text-base leading-7 text-slate-300"
            >
              {initialOperation.description}
            </p>
          </div>
          <span
            data-operation-chip
            class="inline-flex w-fit items-center rounded-full border border-white/10 bg-white/5 px-4 py-2 text-[0.72rem] font-bold uppercase tracking-[0.14em] text-cyan-200"
            >{initialOperation.chip}</span
          >
        </div>
      </section>

      <section class="flex flex-col gap-8">
        <article class="rounded-[1.6rem] border border-white/5 bg-slate-950/40 p-5 lg:p-8 shadow-sm">
          <div
            class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between"
          >
            <div>
              <h2
                class="display-font mt-1 text-[1.12rem] font-semibold tracking-tighter text-white"
              >
                Dimensiones y entradas
              </h2>
              <p
                data-dimension-note
                class="mt-2 text-sm leading-6 text-slate-300 max-w-[40ch]"
              >
              </p>
            </div>
            <button
              data-reset-button
              type="button"
              class="rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm font-semibold text-slate-200 transition hover:border-white/20 hover:bg-white/10 cursor-pointer"
            >
              Restablecer operación
            </button>
          </div>

          
          <div data-dimension-controls class="mt-5"></div>

          <div data-matrix-grids class="mt-5 grid gap-5"></div>

          <div class="mt-6 gap-3 text-center">
            <button
              data-calculate-button
              type="button"
              class="rounded-full bg-linear-to-r from-emerald-400 to-emerald-500 px-5 py-3 text-sm font-semibold text-slate-950 shadow-[0_14px_30px_rgba(16,185,129,0.2)] transition hover:-translate-y-px hover:saturate-110 focus:outline-none focus:ring-4 focus:ring-emerald-400/20 cursor-pointer disabled:pointer-events-none disabled:opacity-50"
            >
              Calcular en backend
            </button>
          </div>
        </article>

        <article class="rounded-[1.6rem] border border-white/5 bg-slate-950/40 p-5 lg:p-8 shadow-sm">
          <div class="flex items-start justify-between gap-4">
            <div>
              <h2
                class="display-font text-[1.12rem] font-semibold tracking-tighter text-white"
              >
                Respuesta
              </h2>
            </div>

            <div data-dimension-matrix class="text-[0.72rem]"></div>
          </div>

          <div
            data-result-matrix
            class="mt-4 overflow-auto rounded-[1.4rem] border border-white/5 bg-slate-950/55 p-5 text-sm leading-6 text-white"
          >
          </div>

          <pre
            data-result-json
            class="mt-4 hidden overflow-auto rounded-[1.4rem] border border-white/5 bg-slate-950/70 p-4 text-xs leading-6 text-slate-200">
          </pre>
        </article>
      </section>
    </div>
  </main>
</Layout>

<script type="module" define:vars={{ backendBaseUrl, operations }}>
  const operationMap = Object.fromEntries(
    operations.map((operation) => [operation.key, operation]),
  );
  const defaultOperationKey = operations[0]?.key ?? "determinante";

  const operationButtons = Array.from(
    document.querySelectorAll("[data-operation-button]"),
  );
  const operationTitle = document.querySelector("[data-operation-title]");
  const operationDescription = document.querySelector(
    "[data-operation-description]",
  );
  const operationChip = document.querySelector("[data-operation-chip]");
  const dimensionNote = document.querySelector("[data-dimension-note]");
  const dimensionControls = document.querySelector("[data-dimension-controls]");
  const matrixGrids = document.querySelector("[data-matrix-grids]");
  const calculateButton = document.querySelector("[data-calculate-button]");
  const resetButton = document.querySelector("[data-reset-button]");
  const resultMessage = document.querySelector("[data-result-message]");
  const resultMatrix = document.querySelector("[data-result-matrix]");
  const resultJson = document.querySelector("[data-result-json]");
  const resultDimension = document.querySelector("[data-dimension-matrix]");
  const mobileAside = document.querySelector("[data-mobile-aside]");
  const mobileOverlay = document.querySelector("[data-mobile-overlay]");
  const mobileMenuButton = document.querySelector("[data-mobile-menu-button]");

  const operationButtonBaseClass =
    "flex items-start justify-between gap-3 rounded-2xl border px-4 py-3 text-left transition duration-200";
  const operationButtonActiveClass =
    "border-cyan-400/20 bg-linear-to-br from-cyan-400/10 to-indigo-500/10 text-white shadow-[0_12px_30px_rgba(0,0,0,0.2)]";
  const operationButtonInactiveClass =
    "border-white/10 bg-white/5 text-slate-300 hover:border-white/20 hover:bg-white/10";

  const state = {
    activeOperationKey: defaultOperationKey,
    dimensions: Object.fromEntries(
      operations.map((operation) => [
        operation.key,
        { ...operation.defaultDimensions },
      ]),
    ),
    matrices: Object.fromEntries(
      operations.map((operation) => [
        operation.key,
        createInitialMatrices(operation),
      ]),
    ),
    loading: false,
  };

  function createMatrix(rows, cols, fill = "") {
    return Array.from({ length: rows }, () =>
      Array.from({ length: cols }, () => fill),
    );
  }

  function setMobileMenuOpen(isOpen) {
    if (!mobileAside || !mobileOverlay || !mobileMenuButton) {
      return;
    }

    mobileAside.classList.toggle("-translate-x-full", !isOpen);
    mobileAside.classList.toggle("translate-x-0", isOpen);
    mobileOverlay.classList.toggle("pointer-events-none", !isOpen);
    mobileOverlay.classList.toggle("opacity-0", !isOpen);
    mobileOverlay.classList.toggle("opacity-100", isOpen);
    mobileMenuButton.setAttribute("aria-expanded", String(isOpen));
  }

  setMobileMenuOpen(false);

  mobileMenuButton?.addEventListener("click", () => {
    const isOpen = mobileMenuButton.getAttribute("aria-expanded") === "true";
    setMobileMenuOpen(!isOpen);
  });

  mobileOverlay?.addEventListener("click", () => setMobileMenuOpen(false));

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") {
      setMobileMenuOpen(false);
    }
  });

  function createInitialMatrices(operation) {
    if (operation.kind === "product") {
      const { rowsA, colsA, colsB } = operation.defaultDimensions;
      return {
        a: createMatrix(rowsA, colsA),
        //filas de B = columnas de A
        b: createMatrix(colsA, colsB),
      };
    }

    if (operation.kind === "flexible-pair") {
      const dims = operation.defaultDimensions;
      return {
        a: createMatrix(dims.rowsA, dims.colsA),
        b: createMatrix(dims.rowsB, dims.colsB),
      };
    }

    if (operation.kind === "single") {
      const { rowsA, colsA } = operation.defaultDimensions;
      return {
        a: createMatrix(rowsA, colsA),
        b: [], // no se usa
      };
    }

    if (operation.kind === "system") {
      const { rowsA, colsA } = operation.defaultDimensions;
      return {
        a: createMatrix(rowsA, colsA),
        b: Array(rowsA).fill(""), // vector b como arreglo 1D
      };
    }

    const { rowsA, colsA, colsB } = operation.defaultDimensions;
    return {
      a: createMatrix(rowsA, colsA),
      b: createMatrix(colsA, colsB),
    };
  }

  function resizeMatrix(matrix, rows, cols) {
    return Array.from({ length: rows }, (_, rowIndex) =>
      Array.from(
        { length: cols },
        (_, colIndex) => matrix?.[rowIndex]?.[colIndex] ?? "",
      ),
    );
  }

  function clampInt(value, min, max) {
    const parsedValue = Number.parseInt(String(value), 10);

    if (Number.isNaN(parsedValue)) {
      return min;
    }

    return Math.min(max, Math.max(min, parsedValue));
  }

  function escapeHtml(value) {
    return String(value)
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;")
      .replaceAll("'", "&#39;");
  }

  function formatNumber(value) {
    if (!Number.isFinite(value)) {
      return String(value);
    }

    const rounded = Math.round(value);
    if (Math.abs(value - rounded) < 1e-10) {
      return String(rounded);
    }

    return Number(value.toFixed(6)).toString();
  }

  function formatExactValue(value) {
    if (value === null || value === undefined) {
      return "";
    }

    return String(value);
  }

  function getActiveOperation() {
    return operationMap[state.activeOperationKey];
  }

  function getDimensions(operationKey) {
    return state.dimensions[operationKey];
  }

  // funcion para sincronizar las matrices con las dimensiones cada vez que el usuario cambia las dimensiones, para evitar que haya matrices con dimensiones diferentes a las especificadas por el usuario, esta funcion se llama cada vez que el usuario cambia las dimensiones o cambia de operacion, y redimensiona las matrices segun las nuevas dimensiones, manteniendo los valores que ya estaban en las celdas que siguen existiendo despues del cambio de dimensiones
  function syncMatricesToDimensions(operationKey) {
    const operation = operationMap[operationKey];
    const dimensions = getDimensions(operationKey);
    const currentMatrices =
      state.matrices[operationKey] ?? createInitialMatrices(operation);

    if (operation.kind === "product") {
      state.matrices[operationKey] = {
        a: resizeMatrix(currentMatrices.a, dimensions.rowsA, dimensions.colsA),
        b: resizeMatrix(currentMatrices.b, dimensions.colsA, dimensions.colsB),
      };
      return;
    }

    if (operation.kind === "flexible-pair") {
      state.matrices[operationKey] = {
        a: resizeMatrix(currentMatrices.a, dimensions.rowsA, dimensions.colsA),
        b: resizeMatrix(currentMatrices.b, dimensions.rowsB, dimensions.colsB),
      };
      return;
    }

    if (operation.kind === "system") {
      // Para sistemas: matriz A redimensionada + vector b redimensionado
      const newB = Array(dimensions.rowsA).fill("");
      for (let i = 0; i < Math.min(currentMatrices.b.length, newB.length); i++) {
        newB[i] = currentMatrices.b[i];
      }
      state.matrices[operationKey] = {
        a: resizeMatrix(currentMatrices.a, dimensions.rowsA, dimensions.colsA),
        b: newB,
      };
      return;
    }

    state.matrices[operationKey] = {
      a: resizeMatrix(currentMatrices.a, dimensions.rowsA, dimensions.colsA),
      b: resizeMatrix(currentMatrices.b, dimensions.colsA, dimensions.colsB),
    };
  }

  function buildDimensionNote(operationKey) {
    const operation = operationMap[operationKey];
    const dimensions = getDimensions(operationKey);

    if (operation.kind === "product") {
      // let str = `${operation.note} A y B usarán ${dimensions.rows} x ${dimensions.cols}.`;
      return `${operation.note}`;
    }

    if (operation.kind === "flexible-pair") {
      // let str = `${operation.note} A será ${dimensions.rowsA} x ${dimensions.colsA} y B será ${dimensions.rowsB} x ${dimensions.colsB}.`;
      return `${operation.note}`;
    }

    // let str = `${operation.note} A será ${dimensions.rowsA} x ${dimensions.colsA} y B será ${dimensions.colsA} x ${dimensions.colsB}.`
    return `${operation.note}`;
  }

  function renderOperationButtons() {
    operationButtons.forEach((button) => {
      const isActive = button.dataset.operationKey === state.activeOperationKey;
      button.setAttribute("aria-pressed", isActive ? "true" : "false");
      button.className = `${operationButtonBaseClass} ${isActive ? operationButtonActiveClass : operationButtonInactiveClass}`;
    });
  }

  function renderDimensionControls() {
    const operation = getActiveOperation();
    const dimensions = getDimensions(operation.key);

    if (!dimensionControls) {
      return;
    }

    // para operaciones de una sola matriz
    if (operation.kind === "single") {
      dimensionControls.innerHTML = `
				<div class="grid gap-4 sm:grid-cols-2">
					<label class="flex flex-col gap-2">
						<span class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-500">Filas</span>
                    <input data-dimension-field="rowsA" type="number" min="1" max="12" value="${dimensions.rowsA}" class="h-11 rounded-xl border border-white/10 bg-white/5 px-4 text-slate-100 outline-none transition focus:border-cyan-400/40 focus:ring-4 focus:ring-cyan-400/10" />
					</label>
					<label class="flex flex-col gap-2">
						<span class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-500">Columnas</span>
                        <input data-dimension-field="colsA" type="number" min="1" max="12" value="${dimensions.colsA}" class="h-11 rounded-xl border border-white/10 bg-white/5 px-4 text-slate-100 outline-none transition focus:border-cyan-400/40 focus:ring-4 focus:ring-cyan-400/10" />
					</label>
				</div>
			`;
      return;
    }

    // suma y resta
    if (operation.kind === "flexible-pair") {
      dimensionControls.innerHTML = `
				<div class="space-y-4 flex flex-row flex-wrap lg:justify-between justify-center">
					<div>
						<p class="mb-3 text-xs font-semibold uppercase tracking-[0.14em] text-slate-400 text-center">Matriz A</p>
						<div class="flex flex-row gap-4">
							<label class="flex flex-col gap-2">
								<span class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-500">Filas A</span>
								<input data-dimension-field="rowsA" type="number" min="1" max="12" value="${dimensions.rowsA}" class="h-11 rounded-xl border border-white/10 bg-white/5 px-4 text-slate-100 outline-none transition focus:border-cyan-400/40 focus:ring-4 focus:ring-cyan-400/10" />
							</label>
							<label class="flex flex-col gap-2">
								<span class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-500">Columnas A</span>
								<input data-dimension-field="colsA" type="number" min="1" max="12" value="${dimensions.colsA}" class="h-11 rounded-xl border border-white/10 bg-white/5 px-4 text-slate-100 outline-none transition focus:border-cyan-400/40 focus:ring-4 focus:ring-cyan-400/10" />
							</label>
						</div>
					</div>
					<div>
						<p class="mb-3 text-xs font-semibold uppercase tracking-[0.14em] text-slate-400 text-center">Matriz B</p>
						<div class="flex flex-row gap-4">
							<label class="flex flex-col gap-2">
								<span class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-500">Filas B</span>
								<input data-dimension-field="rowsB" type="number" min="1" max="12" value="${dimensions.rowsB}" class="h-11 rounded-xl border border-white/10 bg-white/5 px-4 text-slate-100 outline-none transition focus:border-cyan-400/40 focus:ring-4 focus:ring-cyan-400/10" />
							</label>
							<label class="flex flex-col gap-2">
								<span class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-500">Columnas B</span>
								<input data-dimension-field="colsB" type="number" min="1" max="12" value="${dimensions.colsB}" class="h-11 rounded-xl border border-white/10 bg-white/5 px-4 text-slate-100 outline-none transition focus:border-cyan-400/40 focus:ring-4 focus:ring-cyan-400/10" />
							</label>
						</div>
					</div>
				</div>
			`;
      return;
    }

    // para sistemas (gauss, gauss-jordan, cramer)
    if (operation.kind === "system") {
      dimensionControls.innerHTML = `
				<div class="grid gap-4 sm:grid-cols-2">
					<label class="flex flex-col gap-2">
						<span class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-500">Ecuaciones (filas)</span>
						<input data-dimension-field="rowsA" type="number" min="1" max="12" value="${dimensions.rowsA}" class="h-11 rounded-xl border border-white/10 bg-white/5 px-4 text-slate-100 outline-none transition focus:border-cyan-400/40 focus:ring-4 focus:ring-cyan-400/10" />
					</label>
					<label class="flex flex-col gap-2">
						<span class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-500">Incógnitas (columnas)</span>
						<input data-dimension-field="colsA" type="number" min="1" max="12" value="${dimensions.colsA}" class="h-11 rounded-xl border border-white/10 bg-white/5 px-4 text-slate-100 outline-none transition focus:border-cyan-400/40 focus:ring-4 focus:ring-cyan-400/10" />
					</label>
				</div>
			`;
      return;
    }

    // multiplicacion, las dos matrices deben estar sincronizadas numeros de columnas de a = numero de filas de b

    dimensionControls.innerHTML = `
			<div class="grid gap-4 sm:grid-cols-3">
				<label class="flex flex-col gap-2">
					<span class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-500">Filas A</span>
                    <input data-dimension-field="rowsA" type="number" min="1" max="12" value="${dimensions.rowsA}" class="h-11 rounded-xl border border-white/10 bg-white/5 px-4 text-slate-100 outline-none transition focus:border-cyan-400/40 focus:ring-4 focus:ring-cyan-400/10" />
				</label>
				<label class="flex flex-col gap-2">
					<span class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-500">Columnas A</span>
                    <input data-dimension-field="colsA" type="number" min="1" max="12" value="${dimensions.colsA}" class="h-11 rounded-xl border border-white/10 bg-white/5 px-4 text-slate-100 outline-none transition focus:border-cyan-400/40 focus:ring-4 focus:ring-cyan-400/10" />
				</label>
				<label class="flex flex-col gap-2">
					<span class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-500">Columnas B</span>
                    <input data-dimension-field="colsB" type="number" min="1" max="12" value="${dimensions.colsB}" class="h-11 rounded-xl border border-white/10 bg-white/5 px-4 text-slate-100 outline-none transition focus:border-cyan-400/40 focus:ring-4 focus:ring-cyan-400/10" />
				</label>
			</div>
		`;
  }

  //funcion para construir las cards de las matrices, recibe el label, la key para identificar la matriz, las filas, columnas, los valores y un texto de ayuda para mostrar debajo del label de cada card
  function renderMatrixCard(label, matrixKey, rows, cols, values, helperText) {
    return `
			<article class="rounded-[1.6rem] border border-white/10 bg-slate-950/60 p-4 shadow-[0_18px_40px_rgba(0,0,0,0.24)]">
				<div class="flex items-start justify-between gap-4">
					<div>
						<p class="text-[0.72rem] font-bold uppercase tracking-[0.16em] text-slate-400">${label}</p>
						<p class="mt-1 text-sm leading-6 text-slate-400">${helperText}</p>
					</div>
					<span class="inline-flex items-center rounded-full border border-cyan-400/20 bg-cyan-400/10 px-2 py-1 text-[11px] font-bold uppercase tracking-[0.12em] text-cyan-200">${rows} x ${cols}</span>
				</div>
				<div class="mt-4 rounded-[1.2rem] border border-white/10 bg-[radial-gradient(circle_at_20%_20%,rgba(56,189,248,0.08),transparent_24%),radial-gradient(circle_at_82%_8%,rgba(99,102,241,0.12),transparent_28%),linear-gradient(180deg,rgba(15,23,42,0.88),rgba(15,23,42,0.64))] p-4">
					<div class="grid gap-2" style="grid-template-columns: repeat(${cols}, minmax(0, 1fr));">
						${Array.from({ length: rows * cols }, (_, index) => {
              const rowIndex = Math.floor(index / cols);
              const colIndex = index % cols;
              const cellValue = values?.[rowIndex]?.[colIndex] ?? "";

              return `
								<input
									type="number"
									inputmode="decimal"
									data-matrix-key="${matrixKey}"
									data-row-index="${rowIndex}"
									data-col-index="${colIndex}"
									value="${escapeHtml(cellValue)}"
									aria-label="${label} fila ${rowIndex + 1}, columna ${colIndex + 1}"
									class="h-11 rounded-xl border border-white/10 bg-white/5 px-2 text-center text-sm font-semibold text-white outline-none transition placeholder:text-slate-500 focus:border-cyan-400/40 focus:ring-4 focus:ring-cyan-400/10"
								/>
							`;
            }).join("")}
					</div>
				</div>
			</article>
		`;
  }

  //funcion para renderizar el vector b como columna de inputs
  function renderVectorCard(label, vectorKey, size, values, helperText) {
    return `
			<article class="rounded-[1.6rem] border border-white/10 bg-slate-950/60 p-4 shadow-[0_18px_40px_rgba(0,0,0,0.24)] w-2/3">
				<div class=" flex items-center justify-between">
					<h3 class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-300">${label}</h3>
				</div>
				<div class="flex flex-col h-full gap-4 justify-center items-center">
					${Array.from({ length: size }, (_, index) => `
            <input data-matrix-key="${vectorKey}" data-row-index="${index}" data-col-index="0" type="number"  value="${values[index] ?? ""}"  class="h-10 w-full max-w-[7rem] rounded-lg border border-white/10 bg-white/5 px-2 text-center text-sm font-semibold text-white caret-cyan-300 outline-none transition appearance-none focus:border-cyan-400/40 focus:ring-2 focus:ring-cyan-400/10" />
					`).join('')}
				</div>
				<p class="mt-2 text-xs text-slate-500">${helperText}</p>
			</article>
		`;
  }

  //funcion para construir las cards de las matrices segun la operacion escogida por el usuario
  function renderMatrixGrids() {
    const operation = getActiveOperation();
    const dimensions = getDimensions(operation.key);
    const matrices = state.matrices[operation.key];

    if (!matrixGrids) {
      return;
    }

    // si la operacion es de producto
    if (operation.kind === "product") {
      matrixGrids.className = "mt-5 grid gap-5 md:grid-cols-2";
      matrixGrids.innerHTML = [
        renderMatrixCard(
          "Matriz A",
          "a",
          dimensions.rowsA,
          dimensions.colsA,
          matrices.a,
          "Sincronizada con B.",
        ),
        renderMatrixCard(
          "Matriz B",
          "b",
          dimensions.colsA,
          dimensions.colsB,
          matrices.b,
          "Misma forma que A.",
        ),
      ].join("");
      return;
    }

    // si es flexible pair
    if (operation.kind === "flexible-pair") {
      matrixGrids.className = "mt-5 grid gap-5 md:grid-cols-2";
      matrixGrids.innerHTML = [
        renderMatrixCard(
          "Matriz A",
          "a",
          dimensions.rowsA,
          dimensions.colsA,
          matrices.a,
          "Independiente de B.",
        ),
        renderMatrixCard(
          "Matriz B",
          "b",
          dimensions.rowsB,
          dimensions.colsB,
          matrices.b,
          "Independiente de A.",
        ),
      ].join("");
      return;
    }

    if (operation.kind === "system") {
      matrixGrids.className = "mt-5 grid gap-5 lg:grid-cols-2";
      matrixGrids.innerHTML = [
        renderMatrixCard(
          "Matriz A",
          "a",
          dimensions.rowsA,
          dimensions.colsA,
          matrices.a,
          "Coeficientes",
        ),
        renderVectorCard(
          "Vector b (términos independientes)",
          "b",
          dimensions.rowsA,
          matrices.b,
          ""
        ),
      ].join("");
      return;
    }

    if (operation.kind === "single") {
      matrixGrids.className = "mt-5";
      matrixGrids.innerHTML = renderMatrixCard(
        "Matriz A",
        "a",
        dimensions.rowsA,
        dimensions.colsA,
        matrices.a,
        "Única matriz de la operación.",
      );
      return;
    }

    matrixGrids.className = "mt-5 grid gap-5 lg:grid-cols-2";
    matrixGrids.innerHTML = [
      renderMatrixCard(
        "Matriz A",
        "a",
        dimensions.rowsA,
        dimensions.colsA,
        matrices.a,
        "Columnas de A = filas de B.",
      ),
      renderMatrixCard(
        "Matriz B",
        "b",
        dimensions.colsA,
        dimensions.colsB,
        matrices.b,
        `Filas fijas: ${dimensions.colsA}.`,
      ),
    ].join("");
  }

  function renderResultIdle(message) {
    if (resultDimension) {
      resultDimension.textContent = "";
    }

    if (resultMatrix) {
      resultMatrix.innerHTML =
        '<div class="rounded-2xl border border-dashed border-white/10 bg-slate-950/40 p-4 text-sm text-slate-400">Aún no hay cálculo..</div>';
    }

    if (resultJson) {
      resultJson.hidden = true;
      resultJson.textContent = "";
    }
  }

  function renderResultError(errorMessage) {
    if (resultDimension) {
      resultDimension.textContent = "";
    }

    if (resultMatrix) {
      resultMatrix.innerHTML = `
        <div class="rounded-2xl border border-red-400/30 bg-red-500/10 p-4 text-sm">
          <p class="font-semibold text-red-300">Error</p>
          <p class="mt-2 text-red-200">${escapeHtml(String(errorMessage))}</p>
        </div>
      `;
    }

    if (resultJson) {
      resultJson.hidden = true;
      resultJson.textContent = "";
    }
  }

  function renderStepsPanel(steps) {
    if (!Array.isArray(steps) || steps.length === 0) {
      return "";
    }

    const stepsHtml = steps.map((step, idx) => {
      const stepNum = idx + 1;
      const title = escapeHtml(String(step.title ?? ""));
      const description = escapeHtml(String(step.description ?? ""));

      let matrixHtml = "";
      if (step.matrix && Array.isArray(step.matrix)) {
        matrixHtml = `
          <div class="mt-3 overflow-x-auto">
            <div class="inline-block border-l-2 border-r-2 border-slate-500/50 px-2 py-1">
              <table class="border-collapse">
                <tbody>
                  ${step.matrix.map(row => `
                    <tr>
                      ${row.map(cell => `<td class="px-3 py-1.5 text-center text-sm font-medium text-slate-200">${escapeHtml(String(cell))}</td>`).join("")}
                    </tr>
                  `).join("")}
                </tbody>
              </table>
            </div>
          </div>
        `;
      }

      return `
        <li class="relative rounded-2xl border border-white/5 bg-slate-950/20 p-5 p-4 flex flex-col items-center text-center">
          <div class="flex items-center gap-2 mb-2 w-full justify-center">
            <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-slate-900 border border-cyan-400/30 text-[0.6rem] font-bold text-cyan-300 ring-2 ring-slate-950">
              ${stepNum}
            </span>
            <h4 class="text-[0.8rem] font-semibold text-white tracking-wide uppercase">${title}</h4>
          </div>
          ${description ? `<p class="text-[0.75rem] text-slate-400 font-mono leading-relaxed mb-1">${description}</p>` : ""}
          <div class="w-full flex justify-center text-[0.85rem]">
            ${matrixHtml}
          </div>
        </li>
      `;
    }).join("");

    return `
      <div class="mt-8 rounded-2xl border border-white/5 bg-slate-950/40 p-5 lg:p-6">
        <h3 class="font-semibold text-white mb-6 flex items-center gap-2">
          Paso a paso
          <span class="rounded-full bg-white/10 px-2 py-0.5 text-xs text-slate-300">
            ${steps.length}
          </span>
        </h3>
        <ol class="m-0 p-0 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-4">
          ${stepsHtml}
        </ol>
      </div>
    `;
  }

  function renderResultSuccess(operation, responseData) {
    const isCramer = operation.key === "cramer";
    const result = responseData?.result;
    const solution = Array.isArray(responseData?.solution) ? responseData.solution : null;

    function renderSolutionSummary(values) {
      if (!values || values.length === 0) {
        return "";
      }

      const variableNames = ["x", "y", "z", "w", "v", "u"];
      const columns = Math.max(1, Math.min(values.length, 4));
      const items = values.map((value, index) => {
        const name = variableNames[index] ?? `x${index + 1}`;
        return `<div class="rounded-xl border border-white/10 bg-white/5 px-3 py-2 text-center">
          <p class="text-[0.7rem] uppercase tracking-[0.14em] text-slate-400">${name}</p>
          <p class="mt-1 text-base font-semibold text-white">${escapeHtml(formatExactValue(value))}</p>
        </div>`;
      });

      return `
        <div class="mb-4 rounded-2xl border border-emerald-400/20 bg-emerald-400/10 p-4">
          <p class="text-xs font-bold uppercase tracking-[0.16em] text-emerald-200">Solución</p>
          <div class="mt-3 grid gap-2" style="grid-template-columns: repeat(${columns}, minmax(0, 1fr));">
            ${items.join("")}
          </div>
        </div>
      `;
    }

    if (resultMatrix) {
      if (operation.key === "determinante") {
        const determinantText = formatExactValue(result);

        if (determinantText) {
          resultMatrix.innerHTML = `
          <div class="rounded-2xl border border-cyan-400/20 bg-cyan-400/10 p-2 text-center">
            <p class="mt-2 text-xl font-bold text-white">${escapeHtml(determinantText)}</p>
            ${responseData?.method ? `<p class="mt-2 text-sm text-slate-300">Método: ${escapeHtml(responseData.method)}</p>` : ""}
          </div>
        `;
          resultMatrix.innerHTML += renderStepsPanel(responseData?.steps);
        } else {
          resultMatrix.innerHTML =
            '<div class="rounded-2xl border border-dashed border-white/10 bg-slate-950/40 p-4 text-sm text-slate-400">El backend respondió, pero el determinante no es un número válido.</div>';
        }
      } else if (operation.key === "cramer") {
        const determinantText = formatExactValue(responseData?.determinant);
        if (solution && determinantText) {
          resultMatrix.innerHTML = `
        ${renderSolutionSummary(solution)}
        <div class="rounded-2xl border border-cyan-400/20 bg-cyan-400/10 p-4 text-center">
          <p class="text-xs font-bold uppercase tracking-[0.16em] text-cyan-100">Regla de Cramer</p>
          <p class="mt-2 text-sm text-slate-200">Det(A) = ${escapeHtml(determinantText)}</p>
        </div>
      `;
            resultMatrix.innerHTML += renderStepsPanel(responseData?.steps);
        } else {
          resultMatrix.innerHTML =
            '<div class="rounded-2xl border border-dashed border-white/10 bg-slate-950/40 p-4 text-sm text-slate-400">Cramer respondió, pero no devolvió una solución válida.</div>';
        }
      } else if (
        Array.isArray(result) &&
        result.length > 0 &&
        Array.isArray(result[0])
      ) {
        const cols = result[0].length;
        resultMatrix.innerHTML = `
        ${solution ? renderSolutionSummary(solution) : ""}
        <div class="grid gap-2" style="grid-template-columns: repeat(${cols}, minmax(0, 1fr));">
          ${result.map((row) => row.map((cell) => `<div class="grid h-11 place-items-center rounded-xl border border-white/10 bg-white/5 px-2 text-center text-sm font-semibold text-white">${escapeHtml(formatExactValue(cell))}</div>`).join("")).join("")}
        </div>
      `;
          resultMatrix.innerHTML += renderStepsPanel(responseData?.steps);
      } else {
        resultMatrix.innerHTML =
          '<div class="rounded-2xl border border-dashed border-white/10 bg-slate-950/40 p-4 text-sm text-slate-400">El backend respondió, pero no devolvió una matriz válida.</div>';
      }
    }

    if (resultDimension) {
      const method = responseData?.method
        ? escapeHtml(String(responseData.method))
        : "";

      if (operation.key === "cramer") {
        const determinantLabel = formatExactValue(responseData?.determinant) || "N/A";

        resultDimension.innerHTML = `
          <div class="flex flex-col items-end gap-1">
            <span class="inline-flex items-center rounded-full border border-cyan-400/20 bg-cyan-400/10 px-2 py-1 text-[11px] font-bold uppercase tracking-[0.12em] text-cyan-200">Regla de Cramer</span>
            <span class="text-xs text-slate-300">Det(A): ${escapeHtml(determinantLabel)}</span>
          </div>
        `;
      } else if (operation.key === "determinante") {
        // Para determinante mostramos que es un escalar y el método usado
        resultDimension.innerHTML = `
          <div class="flex flex-col items-end gap-1">
            <span class="inline-flex items-center rounded-full border border-cyan-400/20 bg-cyan-400/10 px-2 py-1 text-[11px] font-bold uppercase tracking-[0.12em] text-cyan-200">Escalar</span>
            ${method ? `<span class="text-xs text-slate-300">Método: ${method}</span>` : ""}
          </div>
        `;
      } else if (
        Array.isArray(result) &&
        result.length > 0 &&
        Array.isArray(result[0])
      ) {
        // Para matrices mostramos dimensiones y método si está disponible
        resultDimension.innerHTML = `
          <div class="flex flex-col items-end gap-1">
            <span class="inline-flex items-center rounded-full border border-cyan-400/20 bg-cyan-400/10 px-2 py-1 text-[11px] font-bold uppercase tracking-[0.12em] text-cyan-200">${result.length} x ${result[0].length}</span>
            ${method ? `<span class="text-xs text-slate-300">Método: ${method}</span>` : ``}
          </div>
        `;
      } else {
        resultDimension.textContent = "";
      }
    }

    if (resultJson) {
      resultJson.hidden = false;
      resultJson.textContent = JSON.stringify(responseData, null, 2);
    }
  }

  function updateHeaders() {
    const operation = getActiveOperation();

    if (operationTitle) {
      operationTitle.textContent = operation.title;
    }

    if (operationDescription) {
      operationDescription.textContent = operation.description;
    }

    if (operationChip) {
      operationChip.textContent = operation.chip;
    }

    if (dimensionNote) {
      dimensionNote.textContent = buildDimensionNote(operation.key);
    }

    if (calculateButton) {
      calculateButton.textContent = `Calcular `;
      calculateButton.disabled = state.loading;
    }
  }

  function renderActiveOperation() {
    const operation = getActiveOperation();

    renderOperationButtons();
    updateHeaders();
    renderDimensionControls();
    syncMatricesToDimensions(operation.key);
    renderMatrixGrids();
    renderResultIdle(
      "La respuesta del backend aparecerá aquí cuando calcules la operación.",
    );
  }

  function readMatrix(matrix, label) {
    return matrix.map((row, rowIndex) =>
      row.map((value, colIndex) => {
        const trimmed = String(value).trim();

        if (trimmed === "") {
          throw new Error(
            `${label}: completa la celda (${rowIndex + 1}, ${colIndex + 1}).`,
          );
        }

        const number = Number(trimmed);
        if (!Number.isFinite(number)) {
          throw new Error(
            `${label}: la celda (${rowIndex + 1}, ${colIndex + 1}) debe ser un número real.`,
          );
        }

        return number;
      }),
    );
  }

  function getMatrixShape(matrix) {
    const rows = matrix.length;
    const cols = rows > 0 ? matrix[0].length : 0;
    return { rows, cols };
  }

  function validateOperationDimensions(operation, matrixA, matrixB) {
    const shapeA = getMatrixShape(matrixA);
    const shapeB = getMatrixShape(matrixB);

    if (operation.key === "suma" || operation.key === "resta") {
      if (shapeA.rows !== shapeB.rows || shapeA.cols !== shapeB.cols) {
        throw new Error(
          `${operation.label}: A y B deben tener la misma dimensión. A es ${shapeA.rows}x${shapeA.cols} y B es ${shapeB.rows}x${shapeB.cols}.`,
        );
      }
    }

    if (operation.key === "multiplicacion") {
      if (shapeA.cols !== shapeB.rows) {
        throw new Error(
          `Multiplicación: columnas de A (${shapeA.cols}) debe ser igual a filas de B (${shapeB.rows}).`,
        );
      }
    }
  }

  function buildRequestPayload(operationKey) {
    const operation = operationMap[operationKey];
    const matrices = state.matrices[operationKey];

    const matrixA = readMatrix(matrices.a, "Matriz A");

    if (operation.kind === "single") {
      //validamos cuadrada antes de enviar
      validateOperationDimensions(operation, matrixA, []);
      return { matrix: matrixA };
    }

    if (operation.kind === "system") {
      // Para sistemas: leer matriz A + vector b
      const vectorB = matrices.b.map((val) => {
        const num = Number.parseFloat(String(val));
        if (Number.isNaN(num)) {
          throw new Error(`Vector b contiene un valor no numérico: ${val}`);
        }
        return num;
      });
      return {
        matrix_a: matrixA,
        vector_b: vectorB,
      };
    }

    const matrixB = readMatrix(matrices.b, "Matriz B");
    validateOperationDimensions(operation, matrixA, matrixB);

    return {
      matrix_a: matrixA,
      matrix_b: matrixB,
    };
  }

  function setLoading(isLoading) {
    state.loading = isLoading;

    if (calculateButton) {
      calculateButton.disabled = isLoading;
      calculateButton.textContent = isLoading
        ? "Calculando..."
        : `Calcular ${getActiveOperation().label.toLowerCase()}`;
    }
  }

  function updateOperationState(operationKey) {
    state.activeOperationKey = operationKey;
    renderActiveOperation();
    setMobileMenuOpen(false);
  }

  function resetCurrentOperation() {
    const operation = getActiveOperation();
    state.dimensions[operation.key] = { ...operation.defaultDimensions };
    state.matrices[operation.key] = createInitialMatrices(operation);
    renderActiveOperation();
  }

  async function calculateCurrentOperation() {
    const operation = getActiveOperation();
    if (!backendBaseUrl) {
      renderResultError(
        "No se configuró la URL del servidor. Revisa PUBLIC_API_URL antes de calcular.",
      );
      return;
    }

    const controller = new AbortController();
    const timeoutId = window.setTimeout(() => controller.abort(), 15000);

    setLoading(true);
    renderResultIdle(`Enviando datos a ${operation.endpoint}...`);

    try {
      const payload = buildRequestPayload(operation.key);

      const response = await fetch(`${backendBaseUrl}${operation.endpoint}`, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify(payload),
        signal: controller.signal,
      });

      const responseData = await response.json().catch(() => ({}));

      console.log(responseData);

      if (!response.ok) {
        const errorMessage =
          responseData?.detail ??
          responseData?.message ??
          `Error HTTP ${response.status}`;
        throw new Error(errorMessage);
      }

      renderResultSuccess(operation, responseData);
    } catch (error) {
      let errorMessage = "No se pudo conectar con el backend.";

      if (error instanceof Error) {
        if (error.name === "AbortError") {
          errorMessage =
            "El servidor tardó demasiado en responder. No se generó resultado.";
        } else if (error.message.includes("Failed to fetch")) {
          errorMessage =
            "No se pudo cargar el servidor. Verifica que la API esté activa y accesible.";
        } else {
          errorMessage = error.message;
        }
      }

      renderResultError(errorMessage);
    } finally {
      window.clearTimeout(timeoutId);
      setLoading(false);
    }
  }

  operationButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const operationKey = button.dataset.operationKey ?? defaultOperationKey;
      updateOperationState(operationKey);
    });
  });

  dimensionControls?.addEventListener("input", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLInputElement)) return;
    if (!target.dataset.dimensionField) return;

    const operation = getActiveOperation();
    const dimensions = getDimensions(operation.key);

    const raw = target.value.trim();

    // Permitir cadena vacía para edición móvil (no forzamos min aquí)
    if (raw === "") {
      //  mostrar nota temporal
      if (dimensionNote) dimensionNote.textContent = "Editando dimensiones...";
      return;
    }

    // Sanitizar (solo dígitos) y clamp
    const digits = raw.replace(/[^\d]/g, "");
    const nextValue = clampInt(digits, 1, 12);
    target.value = String(nextValue);

    dimensions[target.dataset.dimensionField] = nextValue;

    if (
      operation.kind === "single" &&
      operation.key !== "transpuesta" &&
      (target.dataset.dimensionField === "rowsA" ||
        target.dataset.dimensionField === "colsA")
    ) {
      dimensions.rowsA = nextValue;
      dimensions.colsA = nextValue;
      const otherField =
        target.dataset.dimensionField === "rowsA" ? "colsA" : "rowsA";
      const otherInput = dimensionControls.querySelector(
        `[data-dimension-field="${otherField}"]`,
      );
      if (otherInput) otherInput.value = String(nextValue);
    }

    syncMatricesToDimensions(operation.key);
    if (dimensionNote)
      dimensionNote.textContent = buildDimensionNote(operation.key);
    renderMatrixGrids();
    renderResultIdle(
      "Las dimensiones cambiaron. Vuelve a calcular para actualizar la respuesta.",
    );
  });

  matrixGrids?.addEventListener("input", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLInputElement)) {
      return;
    }

    const matrixKey = target.dataset.matrixKey;
    if (!matrixKey) {
      return;
    }

    const matrices = state.matrices[state.activeOperationKey];
    const operation = getActiveOperation();

    // Para vector b (en operaciones system)
    if (operation.kind === "system" && matrixKey === "b") {
      const rowIndex = Number(target.dataset.rowIndex ?? 0);
      matrices[matrixKey][rowIndex] = target.value;
    } else {
      // Para matrices regulares
      const rowIndex = Number(target.dataset.rowIndex ?? 0);
      const colIndex = Number(target.dataset.colIndex ?? 0);
      matrices[matrixKey][rowIndex][colIndex] = target.value;
    }
    
    renderResultIdle(
      "Cambiaste una celda. Calcula nuevamente para sincronizar con el backend.",
    );
  });

  calculateButton?.addEventListener("click", () => {
    void calculateCurrentOperation();
  });

  resetButton?.addEventListener("click", () => {
    resetCurrentOperation();
  });

  renderActiveOperation();
</script>
