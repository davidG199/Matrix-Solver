---
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";

const backendBaseUrl = import.meta.env.PUBLIC_API_URL;

const operations = [
  {
    key: "suma",
    label: "Suma",
    title: "Suma de matrices",
    description: "Combina dos matrices con la misma dimension.",
    chip: "Matriz A = Matriz B",
    endpoint: "/matrices/suma",
    kind: "flexible-pair",
    note: "Las matrices A y B deben compartir filas y columnas.",
    defaultDimensions: { rowsA: 3, colsA: 3, rowsB: 3, colsB: 3 },
  },
  {
    key: "resta",
    label: "Resta",
    title: "Resta de matrices",
    description: "Resta matrices de la misma forma.",
    chip: "Matriz A = Matriz B",
    endpoint: "/matrices/resta",
    kind: "flexible-pair",
    note: "La resta exige que A y B tengan exactamente las mismas dimensiones.",
    defaultDimensions: { rowsA: 3, colsA: 3, rowsB: 3, colsB: 3 },
  },
  {
    key: "multiplicacion",
    label: "Multiplicación",
    title: "Multiplicación de matrices",
    description: "Multiplica matrices compatibles.",
    chip: "Matriz A columnas = Matriz B filas",
    endpoint: "/matrices/multiplicacion",
    kind: "product",
    note: "Las columnas de A se sincronizan con las filas de B.",
    defaultDimensions: { rowsA: 2, colsA: 3, colsB: 2 },
  },
];

const initialOperation = operations[0];
---

<Layout title="Matrix Solver | Algebra Lineal">
  <aside
    slot="aside"
    class="flex h-full flex-col gap-6 border-b border-white/10 bg-slate-950/45 px-4 py-6 backdrop-blur-2xl lg:border-b-0 lg:border-r lg:sticky lg:top-0"
  >
    <div
      class="flex items-center gap-3 justify-center border-b pb-4 border-white/20"
    >
      <p class="display-font text-lg font-bold tracking-tighter text-white">
        Matrix Solver
      </p>
    </div>

    <div class="grid gap-2">
      {
        operations.map((operation, index) => (
          <button
            type="button"
            data-operation-button
            data-operation-key={operation.key}
            class={`flex items-start justify-between  border px-4 py-3 transition duration-200 ${index === 0 ? " text-white shadow-[0_12px_30px_rgba(0,0,0,0.2)]" : "border-white/10 bg-white/5 text-slate-300 hover:border-white/20 hover:bg-white/10"}`}
            aria-pressed={index === 0 ? "true" : "false"}
          >
            <span>
              <strong class="block text-sm font-semibold">
                {operation.label}
              </strong>
            </span>
          </button>
        ))
      }
    </div>
  </aside>

  <main
    slot="main"
    class="relative min-h-screen overflow-hidden px-4 py-5 sm:px-6 lg:px-10 lg:py-10"
  >
    <div
      class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_14%_12%,rgba(56,189,248,0.16),transparent_24%),radial-gradient(circle_at_85%_8%,rgba(99,102,241,0.2),transparent_26%),radial-gradient(circle_at_50%_100%,rgba(16,185,129,0.14),transparent_28%)]"
    >
    </div>

    <div
      class="pointer-events-none absolute inset-0 bg-[linear-gradient(180deg,rgba(5,8,16,0.62),rgba(5,8,16,0.24)_42%,rgba(5,8,16,0.72))]"
    >
    </div>

    <div class="relative mx-auto flex max-w-7xl flex-col gap-6">
      <section class="p-6">
        <div
          class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between"
        >
          <div class="max-w-4xl">
            <h1
              data-operation-title
              class="display-font mt-2 text-4xl font-bold tracking-tighter text-white sm:text-5xl"
            >
              {initialOperation.title}
            </h1>
            <p
              data-operation-description
              class="mt-3 max-w-3xl text-base leading-7 text-slate-300"
            >
              {initialOperation.description}
            </p>
          </div>
          <span
            data-operation-chip
            class="inline-flex w-fit items-center rounded-full border border-white/10 bg-white/5 px-4 py-2 text-[0.72rem] font-bold uppercase tracking-[0.14em] text-cyan-200"
            >{initialOperation.chip}</span
          >
        </div>
      </section>

      <section
        class="grid gap-6 xl:grid-cols-[minmax(0,1.15fr)_minmax(320px,0.85fr)]"
      >
        <article class="p-5">
          <div
            class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between"
          >
            <div>
              <h2
                class="display-font mt-1 text-[1.12rem] font-semibold tracking-tighter text-white"
              >
                Dimensiones y entradas
              </h2>
              <p
                data-dimension-note
                class="mt-2 text-sm leading-6 text-slate-300 max-w-[40ch]"
              >
              </p>
            </div>
            <button
              data-reset-button
              type="button"
              class="rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm font-semibold text-slate-200 transition hover:border-white/20 hover:bg-white/10"
            >
              Restablecer operación
            </button>
          </div>

          <div data-dimension-controls class="mt-5"></div>

          <div data-matrix-grids class="mt-5 grid gap-5"></div>

          <div
            class="mt-6 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between"
          >
            <button
              data-calculate-button
              type="button"
              class="rounded-full bg-linear-to-r from-emerald-400 to-emerald-500 px-5 py-3 text-sm font-semibold text-slate-950 shadow-[0_14px_30px_rgba(16,185,129,0.2)] transition hover:-translate-y-px hover:saturate-110 focus:outline-none focus:ring-4 focus:ring-emerald-400/20"
            >
              Calcular en backend
            </button>
          </div>
        </article>

        <div class="grid gap-6">
          <article class="p-5">
            <div class="flex items-start justify-between gap-4">
              <div>
                <p
                  class="text-[0.72rem] font-bold uppercase tracking-[0.16em] text-slate-400"
                >
                  Respuesta
                </p>
              </div>
            </div>

            <div
              data-result-matrix
              class="mt-4 overflow-auto rounded-[1.4rem] border border-white/10 bg-slate-950/55 p-4 text-sm leading-6 text-white"
            >
            </div>

            <pre
              data-result-json
              class="mt-4 hidden overflow-auto rounded-[1.4rem] border border-white/10 bg-slate-950/70 p-4 text-xs leading-6 text-slate-200">
            </pre>
          </article>
        </div>
      </section>
    </div>
  </main>
</Layout>

<script type="module" define:vars={{ backendBaseUrl, operations }}>
  const operationMap = Object.fromEntries(
    operations.map((operation) => [operation.key, operation]),
  );
  const defaultOperationKey = operations[0]?.key ?? "suma";

  const operationButtons = Array.from(
    document.querySelectorAll("[data-operation-button]"),
  );
  const operationTitle = document.querySelector("[data-operation-title]");
  const operationDescription = document.querySelector(
    "[data-operation-description]",
  );
  const operationChip = document.querySelector("[data-operation-chip]");
  const dimensionNote = document.querySelector("[data-dimension-note]");
  const dimensionControls = document.querySelector("[data-dimension-controls]");
  const matrixGrids = document.querySelector("[data-matrix-grids]");
  const validationMessage = document.querySelector("[data-validation-message]");
  const calculateButton = document.querySelector("[data-calculate-button]");
  const resetButton = document.querySelector("[data-reset-button]");
  const resultChip = document.querySelector("[data-result-chip]");
  const resultMessage = document.querySelector("[data-result-message]");
  const resultMatrix = document.querySelector("[data-result-matrix]");
  const resultJson = document.querySelector("[data-result-json]");

  const operationButtonBaseClass =
    "flex items-start justify-between gap-3 rounded-2xl border px-4 py-3 text-left transition duration-200";
  const operationButtonActiveClass =
    "border-cyan-400/20 bg-linear-to-br from-cyan-400/10 to-indigo-500/10 text-white shadow-[0_12px_30px_rgba(0,0,0,0.2)]";
  const operationButtonInactiveClass =
    "border-white/10 bg-white/5 text-slate-300 hover:border-white/20 hover:bg-white/10";

  const state = {
    activeOperationKey: defaultOperationKey,
    dimensions: Object.fromEntries(
      operations.map((operation) => [
        operation.key,
        { ...operation.defaultDimensions },
      ]),
    ),
    matrices: Object.fromEntries(
      operations.map((operation) => [
        operation.key,
        createInitialMatrices(operation),
      ]),
    ),
    loading: false,
  };

  function createMatrix(rows, cols, fill = "") {
    return Array.from({ length: rows }, () =>
      Array.from({ length: cols }, () => fill),
    );
  }

  function createInitialMatrices(operation) {
    if (operation.kind === "pair") {
      const { rows, cols } = operation.defaultDimensions;
      return {
        a: createMatrix(rows, cols),
        b: createMatrix(rows, cols),
      };
    }

    if (operation.kind === "flexible-pair") {
      const dims = operation.defaultDimensions;
      return {
        a: createMatrix(dims.rowsA, dims.colsA),
        b: createMatrix(dims.rowsB, dims.colsB),
      };
    }

    const { rowsA, colsA, colsB } = operation.defaultDimensions;
    return {
      a: createMatrix(rowsA, colsA),
      b: createMatrix(colsA, colsB),
    };
  }

  function resizeMatrix(matrix, rows, cols) {
    return Array.from({ length: rows }, (_, rowIndex) =>
      Array.from(
        { length: cols },
        (_, colIndex) => matrix?.[rowIndex]?.[colIndex] ?? "",
      ),
    );
  }

  function clampInt(value, min, max) {
    const parsedValue = Number.parseInt(String(value), 10);

    if (Number.isNaN(parsedValue)) {
      return min;
    }

    return Math.min(max, Math.max(min, parsedValue));
  }

  function escapeHtml(value) {
    return String(value)
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;")
      .replaceAll("'", "&#39;");
  }

  function formatNumber(value) {
    if (!Number.isFinite(value)) {
      return String(value);
    }

    const rounded = Math.round(value);
    if (Math.abs(value - rounded) < 1e-10) {
      return String(rounded);
    }

    return Number(value.toFixed(6)).toString();
  }

  function getActiveOperation() {
    return operationMap[state.activeOperationKey];
  }

  function getDimensions(operationKey) {
    return state.dimensions[operationKey];
  }

  function syncMatricesToDimensions(operationKey) {
    const operation = operationMap[operationKey];
    const dimensions = getDimensions(operationKey);
    const currentMatrices =
      state.matrices[operationKey] ?? createInitialMatrices(operation);

    if (operation.kind === "pair") {
      state.matrices[operationKey] = {
        a: resizeMatrix(currentMatrices.a, dimensions.rows, dimensions.cols),
        b: resizeMatrix(currentMatrices.b, dimensions.rows, dimensions.cols),
      };
      return;
    }

    if (operation.kind === "flexible-pair") {
      state.matrices[operationKey] = {
        a: resizeMatrix(currentMatrices.a, dimensions.rowsA, dimensions.colsA),
        b: resizeMatrix(currentMatrices.b, dimensions.rowsB, dimensions.colsB),
      };
      return;
    }

    state.matrices[operationKey] = {
      a: resizeMatrix(currentMatrices.a, dimensions.rowsA, dimensions.colsA),
      b: resizeMatrix(currentMatrices.b, dimensions.colsA, dimensions.colsB),
    };
  }

  function buildDimensionNote(operationKey) {
    const operation = operationMap[operationKey];
    const dimensions = getDimensions(operationKey);

    if (operation.kind === "pair") {
      return `${operation.note} A y B usarán ${dimensions.rows} x ${dimensions.cols}.`;
    }

    if (operation.kind === "flexible-pair") {
      return `${operation.note} A será ${dimensions.rowsA} x ${dimensions.colsA} y B será ${dimensions.rowsB} x ${dimensions.colsB}.`;
    }

    return `${operation.note} A será ${dimensions.rowsA} x ${dimensions.colsA} y B será ${dimensions.colsA} x ${dimensions.colsB}.`;
  }

  function renderOperationButtons() {
    operationButtons.forEach((button) => {
      const isActive = button.dataset.operationKey === state.activeOperationKey;
      button.setAttribute("aria-pressed", isActive ? "true" : "false");
      button.className = `${operationButtonBaseClass} ${isActive ? operationButtonActiveClass : operationButtonInactiveClass}`;
    });
  }

  function renderDimensionControls() {
    const operation = getActiveOperation();
    const dimensions = getDimensions(operation.key);

    if (!dimensionControls) {
      return;
    }

    if (operation.kind === "pair") {
      dimensionControls.innerHTML = `
				<div class="grid gap-4 sm:grid-cols-2">
					<label class="flex flex-col gap-2">
						<span class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-500">Filas</span>
                    <input data-dimension-field="rows" type="number" min="1" max="12" value="${dimensions.rows}" class="h-11 rounded-xl border border-white/10 bg-white/5 px-4 text-slate-100 outline-none transition focus:border-cyan-400/40 focus:ring-4 focus:ring-cyan-400/10" />
					</label>
					<label class="flex flex-col gap-2">
						<span class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-500">Columnas</span>
                        <input data-dimension-field="cols" type="number" min="1" max="12" value="${dimensions.cols}" class="h-11 rounded-xl border border-white/10 bg-white/5 px-4 text-slate-100 outline-none transition focus:border-cyan-400/40 focus:ring-4 focus:ring-cyan-400/10" />
					</label>
				</div>
			`;
      return;
    }

    if (operation.kind === "flexible-pair") {
      dimensionControls.innerHTML = `
				<div class="space-y-4 flex flex-row flex-wrap lg:justify-between justify-center">
					<div>
						<p class="mb-3 text-xs font-semibold uppercase tracking-[0.14em] text-slate-400 text-center">Matriz A</p>
						<div class="flex flex-row gap-4">
							<label class="flex flex-col gap-2">
								<span class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-500">Filas A</span>
								<input data-dimension-field="rowsA" type="number" min="1" max="12" value="${dimensions.rowsA}" class="h-11 rounded-xl border border-white/10 bg-white/5 px-4 text-slate-100 outline-none transition focus:border-cyan-400/40 focus:ring-4 focus:ring-cyan-400/10" />
							</label>
							<label class="flex flex-col gap-2">
								<span class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-500">Columnas A</span>
								<input data-dimension-field="colsA" type="number" min="1" max="12" value="${dimensions.colsA}" class="h-11 rounded-xl border border-white/10 bg-white/5 px-4 text-slate-100 outline-none transition focus:border-cyan-400/40 focus:ring-4 focus:ring-cyan-400/10" />
							</label>
						</div>
					</div>
					<div>
						<p class="mb-3 text-xs font-semibold uppercase tracking-[0.14em] text-slate-400 text-center">Matriz B</p>
						<div class="flex flex-row gap-4">
							<label class="flex flex-col gap-2">
								<span class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-500">Filas B</span>
								<input data-dimension-field="rowsB" type="number" min="1" max="12" value="${dimensions.rowsB}" class="h-11 rounded-xl border border-white/10 bg-white/5 px-4 text-slate-100 outline-none transition focus:border-cyan-400/40 focus:ring-4 focus:ring-cyan-400/10" />
							</label>
							<label class="flex flex-col gap-2">
								<span class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-500">Columnas B</span>
								<input data-dimension-field="colsB" type="number" min="1" max="12" value="${dimensions.colsB}" class="h-11 rounded-xl border border-white/10 bg-white/5 px-4 text-slate-100 outline-none transition focus:border-cyan-400/40 focus:ring-4 focus:ring-cyan-400/10" />
							</label>
						</div>
					</div>
				</div>
			`;
      return;
    }

    dimensionControls.innerHTML = `
			<div class="grid gap-4 sm:grid-cols-3">
				<label class="flex flex-col gap-2">
					<span class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-500">Filas A</span>
                    <input data-dimension-field="rowsA" type="number" min="1" max="12" value="${dimensions.rowsA}" class="h-11 rounded-xl border border-white/10 bg-white/5 px-4 text-slate-100 outline-none transition focus:border-cyan-400/40 focus:ring-4 focus:ring-cyan-400/10" />
				</label>
				<label class="flex flex-col gap-2">
					<span class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-500">Columnas A</span>
                    <input data-dimension-field="colsA" type="number" min="1" max="12" value="${dimensions.colsA}" class="h-11 rounded-xl border border-white/10 bg-white/5 px-4 text-slate-100 outline-none transition focus:border-cyan-400/40 focus:ring-4 focus:ring-cyan-400/10" />
				</label>
				<label class="flex flex-col gap-2">
					<span class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-500">Columnas B</span>
                    <input data-dimension-field="colsB" type="number" min="1" max="12" value="${dimensions.colsB}" class="h-11 rounded-xl border border-white/10 bg-white/5 px-4 text-slate-100 outline-none transition focus:border-cyan-400/40 focus:ring-4 focus:ring-cyan-400/10" />
				</label>
			</div>
		`;
  }

  function renderMatrixCard(label, matrixKey, rows, cols, values, helperText) {
    return `
			<article class="rounded-[1.6rem] border border-white/10 bg-slate-950/60 p-4 shadow-[0_18px_40px_rgba(0,0,0,0.24)]">
				<div class="flex items-start justify-between gap-4">
					<div>
						<p class="text-[0.72rem] font-bold uppercase tracking-[0.16em] text-slate-400">${label}</p>
						<p class="mt-1 text-sm leading-6 text-slate-400">${helperText}</p>
					</div>
					<span class="inline-flex items-center rounded-full border border-cyan-400/20 bg-cyan-400/10 px-2 py-1 text-[11px] font-bold uppercase tracking-[0.12em] text-cyan-200">${rows} x ${cols}</span>
				</div>
				<div class="mt-4 rounded-[1.2rem] border border-white/10 bg-[radial-gradient(circle_at_20%_20%,rgba(56,189,248,0.08),transparent_24%),radial-gradient(circle_at_82%_8%,rgba(99,102,241,0.12),transparent_28%),linear-gradient(180deg,rgba(15,23,42,0.88),rgba(15,23,42,0.64))] p-4">
					<div class="grid gap-2" style="grid-template-columns: repeat(${cols}, minmax(0, 1fr));">
						${Array.from({ length: rows * cols }, (_, index) => {
              const rowIndex = Math.floor(index / cols);
              const colIndex = index % cols;
              const cellValue = values?.[rowIndex]?.[colIndex] ?? "";

              return `
								<input
									type="number"
									inputmode="decimal"
									data-matrix-key="${matrixKey}"
									data-row-index="${rowIndex}"
									data-col-index="${colIndex}"
									value="${escapeHtml(cellValue)}"
									aria-label="${label} fila ${rowIndex + 1}, columna ${colIndex + 1}"
									class="h-11 rounded-xl border border-white/10 bg-white/5 px-2 text-center text-sm font-semibold text-white outline-none transition placeholder:text-slate-500 focus:border-cyan-400/40 focus:ring-4 focus:ring-cyan-400/10"
								/>
							`;
            }).join("")}
					</div>
				</div>
			</article>
		`;
  }

  function renderMatrixGrids() {
    const operation = getActiveOperation();
    const dimensions = getDimensions(operation.key);
    const matrices = state.matrices[operation.key];

    if (!matrixGrids) {
      return;
    }

    if (operation.kind === "pair") {
      matrixGrids.className = "mt-5 grid gap-5 lg:grid-cols-2";
      matrixGrids.innerHTML = [
        renderMatrixCard(
          "Matriz A",
          "a",
          dimensions.rows,
          dimensions.cols,
          matrices.a,
          "Sincronizada con B.",
        ),
        renderMatrixCard(
          "Matriz B",
          "b",
          dimensions.rows,
          dimensions.cols,
          matrices.b,
          "Misma forma que A.",
        ),
      ].join("");
      return;
    }

    if (operation.kind === "flexible-pair") {
      matrixGrids.className = "mt-5 grid gap-5 lg:grid-cols-2";
      matrixGrids.innerHTML = [
        renderMatrixCard(
          "Matriz A",
          "a",
          dimensions.rowsA,
          dimensions.colsA,
          matrices.a,
          "Independiente de B.",
        ),
        renderMatrixCard(
          "Matriz B",
          "b",
          dimensions.rowsB,
          dimensions.colsB,
          matrices.b,
          "Independiente de A.",
        ),
      ].join("");
      return;
    }

    matrixGrids.className = "mt-5 grid gap-5 lg:grid-cols-2";
    matrixGrids.innerHTML = [
      renderMatrixCard(
        "Matriz A",
        "a",
        dimensions.rowsA,
        dimensions.colsA,
        matrices.a,
        "Columnas de A = filas de B.",
      ),
      renderMatrixCard(
        "Matriz B",
        "b",
        dimensions.colsA,
        dimensions.colsB,
        matrices.b,
        `Filas fijas: ${dimensions.colsA}.`,
      ),
    ].join("");
  }

  function renderResultIdle(message) {
    if (resultChip) {
      resultChip.textContent = "Esperando";
      resultChip.className =
        "inline-flex items-center justify-center rounded-full border border-white/10 bg-white/5 px-3 py-1 text-[0.72rem] font-bold uppercase tracking-[0.12em] text-slate-300";
    }

    if (resultMessage) {
      resultMessage.textContent = message;
    }

    if (resultMatrix) {
      resultMatrix.innerHTML =
        '<div class="rounded-2xl border border-dashed border-white/10 bg-slate-950/40 p-4 text-sm text-slate-400">Aún no hay cálculo..</div>';
    }

    if (resultJson) {
      resultJson.hidden = true;
      resultJson.textContent = "";
    }
  }

  function renderResultError(message) {
    if (resultChip) {
      resultChip.textContent = "Error";
      resultChip.className =
        "inline-flex items-center justify-center rounded-full border border-rose-400/20 bg-rose-400/10 px-3 py-1 text-[0.72rem] font-bold uppercase tracking-[0.12em] text-rose-200";
    }

    if (resultMessage) {
      resultMessage.textContent = message;
    }

    if (resultMatrix) {
      resultMatrix.innerHTML = `
        <div class="rounded-2xl border border-rose-400/20 bg-rose-400/10 p-4">
          <p class="text-sm font-semibold text-rose-100">No hay resultado</p>
          <p class="mt-2 text-sm leading-6 text-rose-100/80">${escapeHtml(message)}</p>
        </div>
      `;
    }

    if (resultJson) {
      resultJson.hidden = true;
      resultJson.textContent = "";
    }
  }

  function renderResultSuccess(operation, responseData) {
    const matrix = responseData?.result;

    if (resultChip) {
      resultChip.textContent = "Correcto";
      resultChip.className =
        "inline-flex items-center justify-center rounded-full border border-emerald-400/20 bg-emerald-400/10 px-3 py-1 text-[0.72rem] font-bold uppercase tracking-[0.12em] text-emerald-200";
    }

    if (resultMessage) {
      resultMessage.textContent = `Respuesta recibida desde ${operation.endpoint}.`;
    }

    if (resultMatrix) {
      if (
        Array.isArray(matrix) &&
        matrix.length > 0 &&
        Array.isArray(matrix[0])
      ) {
        const cols = matrix[0].length;
        resultMatrix.innerHTML = `
					<div class="grid gap-2" style="grid-template-columns: repeat(${cols}, minmax(0, 1fr));">
						${matrix.map((row) => row.map((cell) => `<div class="grid h-11 place-items-center rounded-xl border border-white/10 bg-white/5 px-2 text-center text-sm font-semibold text-white">${escapeHtml(formatNumber(Number(cell)))}</div>`).join("")).join("")}
					</div>
				`;
      } else {
        resultMatrix.innerHTML =
          '<div class="rounded-2xl border border-dashed border-white/10 bg-slate-950/40 p-4 text-sm text-slate-400">El backend respondió, pero no devolvió una matriz válida.</div>';
      }
    }

    if (resultJson) {
      resultJson.hidden = false;
      resultJson.textContent = JSON.stringify(responseData, null, 2);
    }
  }

  function updateHeaders() {
    const operation = getActiveOperation();

    if (operationTitle) {
      operationTitle.textContent = operation.title;
    }

    if (operationDescription) {
      operationDescription.textContent = operation.description;
    }

    if (operationChip) {
      operationChip.textContent = operation.chip;
    }

    if (dimensionNote) {
      dimensionNote.textContent = buildDimensionNote(operation.key);
    }

    if (validationMessage) {
      validationMessage.textContent =
        "Completa las matrices y pulsa calcular para enviar la petición al backend.";
    }

    if (calculateButton) {
      calculateButton.textContent = `Calcular ${operation.label.toLowerCase()}`;
      calculateButton.disabled = state.loading;
    }
  }

  function renderActiveOperation() {
    const operation = getActiveOperation();

    renderOperationButtons();
    updateHeaders();
    renderDimensionControls();
    syncMatricesToDimensions(operation.key);
    renderMatrixGrids();
    renderResultIdle(
      "La respuesta del backend aparecerá aquí cuando calcules la operación.",
    );
  }

  function readMatrix(matrix, label) {
    return matrix.map((row, rowIndex) =>
      row.map((value, colIndex) => {
        const trimmed = String(value).trim();

        if (trimmed === "") {
          throw new Error(
            `${label}: completa la celda (${rowIndex + 1}, ${colIndex + 1}).`,
          );
        }

        const number = Number(trimmed);
        if (!Number.isFinite(number)) {
          throw new Error(
            `${label}: la celda (${rowIndex + 1}, ${colIndex + 1}) debe ser un número real.`,
          );
        }

        return number;
      }),
    );
  }

  function getMatrixShape(matrix) {
    const rows = matrix.length;
    const cols = rows > 0 ? matrix[0].length : 0;
    return { rows, cols };
  }

  function validateOperationDimensions(operation, matrixA, matrixB) {
    const shapeA = getMatrixShape(matrixA);
    const shapeB = getMatrixShape(matrixB);

    if (operation.key === "suma" || operation.key === "resta") {
      if (shapeA.rows !== shapeB.rows || shapeA.cols !== shapeB.cols) {
        throw new Error(
          `${operation.label}: A y B deben tener la misma dimensión. A es ${shapeA.rows}x${shapeA.cols} y B es ${shapeB.rows}x${shapeB.cols}.`,
        );
      }
    }

    if (operation.key === "multiplicacion") {
      if (shapeA.cols !== shapeB.rows) {
        throw new Error(
          `Multiplicación: columnas de A (${shapeA.cols}) debe ser igual a filas de B (${shapeB.rows}).`,
        );
      }
    }
  }

  function buildRequestPayload(operationKey) {
    const operation = operationMap[operationKey];
    const matrices = state.matrices[operationKey];

    const matrixA = readMatrix(matrices.a, "Matriz A");
    const matrixB = readMatrix(matrices.b, "Matriz B");

    validateOperationDimensions(operation, matrixA, matrixB);

    return {
      matrix_a: matrixA,
      matrix_b: matrixB,
    };
  }

  function setLoading(isLoading) {
    state.loading = isLoading;

    if (calculateButton) {
      calculateButton.disabled = isLoading;
      calculateButton.textContent = isLoading
        ? "Calculando..."
        : `Calcular ${getActiveOperation().label.toLowerCase()}`;
    }
  }

  function updateOperationState(operationKey) {
    state.activeOperationKey = operationKey;
    renderActiveOperation();
  }

  function resetCurrentOperation() {
    const operation = getActiveOperation();
    state.dimensions[operation.key] = { ...operation.defaultDimensions };
    state.matrices[operation.key] = createInitialMatrices(operation);
    renderActiveOperation();
  }

  async function calculateCurrentOperation() {
    const operation = getActiveOperation();
    if (!backendBaseUrl) {
      renderResultError(
        "No se configuró la URL del servidor. Revisa PUBLIC_API_URL antes de calcular.",
      );
      if (validationMessage) {
        validationMessage.textContent =
          "Falta la configuración del backend, por eso no se puede generar resultado.";
      }
      return;
    }

    const controller = new AbortController();
    const timeoutId = window.setTimeout(() => controller.abort(), 15000);

    setLoading(true);
    renderResultIdle(`Enviando datos a ${operation.endpoint}...`);

    try {
      const payload = buildRequestPayload(operation.key);

      const response = await fetch(`${backendBaseUrl}${operation.endpoint}`, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify(payload),
        signal: controller.signal,
      });

      const responseData = await response.json().catch(() => ({}));

      if (!response.ok) {
        const errorMessage =
          responseData?.detail ??
          responseData?.message ??
          `Error HTTP ${response.status}`;
        throw new Error(errorMessage);
      }

      renderResultSuccess(operation, responseData);
      if (validationMessage) {
        validationMessage.textContent = "Cálculo completado correctamente.";
      }
    } catch (error) {
      let errorMessage = "No se pudo conectar con el backend.";

      if (error instanceof Error) {
        if (error.name === "AbortError") {
          errorMessage =
            "El servidor tardó demasiado en responder. No se generó resultado.";
        } else if (error.message.includes("Failed to fetch")) {
          errorMessage =
            "No se pudo cargar el servidor. Verifica que la API esté activa y accesible.";
        } else {
          errorMessage = error.message;
        }
      }

      renderResultError(errorMessage);
      if (validationMessage) {
        validationMessage.textContent = errorMessage;
      }
    } finally {
      window.clearTimeout(timeoutId);
      setLoading(false);
    }
  }

  operationButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const operationKey = button.dataset.operationKey ?? defaultOperationKey;
      updateOperationState(operationKey);
    });
  });

  dimensionControls?.addEventListener("input", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLInputElement)) return;
    if (!target.dataset.dimensionField) return;

    const operation = getActiveOperation();
    const dimensions = getDimensions(operation.key);

    const raw = target.value.trim();

    // Permitir cadena vacía para edición móvil (no forzamos min aquí)
    if (raw === "") {
      // opcional: mostrar nota temporal
      if (dimensionNote) dimensionNote.textContent = "Editando dimensiones...";
      return;
    }

    // Sanitizar (solo dígitos) y clamp
    const digits = raw.replace(/[^\d]/g, "");
    const nextValue = clampInt(digits, 1, 12);

    target.value = String(nextValue);
    dimensions[target.dataset.dimensionField] = nextValue;

    syncMatricesToDimensions(operation.key);
    if (dimensionNote)
      dimensionNote.textContent = buildDimensionNote(operation.key);
    renderMatrixGrids();
    renderResultIdle(
      "Las dimensiones cambiaron. Vuelve a calcular para actualizar la respuesta.",
    );
  });

  matrixGrids?.addEventListener("input", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLInputElement)) {
      return;
    }

    const matrixKey = target.dataset.matrixKey;
    if (!matrixKey) {
      return;
    }

    const rowIndex = Number(target.dataset.rowIndex ?? 0);
    const colIndex = Number(target.dataset.colIndex ?? 0);
    const matrices = state.matrices[state.activeOperationKey];

    matrices[matrixKey][rowIndex][colIndex] = target.value;
    renderResultIdle(
      "Cambiaste una celda. Calcula nuevamente para sincronizar con el backend.",
    );
  });

  calculateButton?.addEventListener("click", () => {
    void calculateCurrentOperation();
  });

  resetButton?.addEventListener("click", () => {
    resetCurrentOperation();
  });

  renderActiveOperation();
</script>
