---
const { rows = 3, cols = 4 } = Astro.props;
---

<section class="mb-5 rounded-3xl border border-slate-200/70 bg-white/80 p-5 shadow-[0_28px_65px_rgba(15,23,42,0.12)] backdrop-blur-xl">
	<div class="mb-4 flex flex-col gap-3 lg:flex-row lg:items-start lg:justify-between">
		<div>
			<p class="mb-1 text-[0.72rem] font-bold uppercase tracking-[0.16em] text-slate-500">Dimension configurator</p>
			<h2 class="display-font text-[1.12rem] font-semibold tracking-[-0.03em]">Define el tamano de tu matriz</h2>
		</div>
		<p class="max-w-[27ch] text-sm leading-6 text-slate-500">Ingresa las filas y columnas antes de generar el grid de valores.</p>
	</div>

	<div class="grid grid-cols-1 gap-4 md:grid-cols-[repeat(2,minmax(0,1fr))_auto] md:items-end">
		<label class="flex flex-col gap-1.5" for="matrix-rows">
			<span class="text-sm font-semibold text-slate-500">Rows (n)</span>
			<input id="matrix-rows" class="h-11 rounded-xl border border-slate-300/70 bg-white/95 px-4 text-slate-900 shadow-[inset_0_1px_2px_rgba(15,23,42,0.05)] outline-none transition focus:border-blue-500 focus:ring-4 focus:ring-blue-500/10" data-rows type="number" min="1" max="6" value={rows} />
		</label>

		<label class="flex flex-col gap-1.5" for="matrix-cols">
			<span class="text-sm font-semibold text-slate-500">Columns (m)</span>
			<input id="matrix-cols" class="h-11 rounded-xl border border-slate-300/70 bg-white/95 px-4 text-slate-900 shadow-[inset_0_1px_2px_rgba(15,23,42,0.05)] outline-none transition focus:border-blue-500 focus:ring-4 focus:ring-blue-500/10" data-cols type="number" min="1" max="6" value={cols} />
		</label>

		<button type="button" class="h-11 rounded-xl bg-gradient-to-r from-blue-600 to-indigo-700 px-4 font-semibold text-white shadow-[0_12px_26px_rgba(47,73,242,0.24)] transition hover:-translate-y-px hover:saturate-110 focus:-translate-y-px focus:outline-none focus:ring-4 focus:ring-blue-500/20" data-generate-matrix>
			Generar Matriz
		</button>
	</div>
</section>
