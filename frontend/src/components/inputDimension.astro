---
---

<section data-dimension-shell class="hidden rounded-4xl border border-white/10 bg-white/5 p-5 shadow-[0_28px_80px_rgba(0,0,0,0.32)] backdrop-blur-2xl">
	<div class="flex flex-col gap-3 lg:flex-row lg:items-start lg:justify-between">
		<div>
			<p class="text-[0.72rem] font-bold uppercase tracking-[0.16em] text-cyan-200">Configuracion</p>
			<h2 data-operation-config-title class="display-font mt-1 text-[1.12rem] font-semibold tracking-tighter text-white">Dimensiones de matrices</h2>
		</div>
		<span data-operation-badge class="inline-flex w-fit items-center rounded-full border border-cyan-400/20 bg-cyan-400/10 px-3 py-1 text-[0.72rem] font-bold uppercase tracking-[0.14em] text-cyan-200">Validacion automatica</span>
	</div>

	<div data-dimension-cards class="mt-5 grid gap-4 lg:grid-cols-2"></div>

	<div class="mt-5 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
		<p data-dimension-message class="text-sm leading-6 text-slate-300">Selecciona una operacion para ver sus restricciones.</p>
		<button data-apply-dimensions type="button" class="rounded-full bg-linear-to-r from-cyan-400 to-indigo-500 px-5 py-3 text-sm font-semibold text-slate-950 shadow-[0_14px_30px_rgba(34,211,238,0.22)] transition hover:-translate-y-px hover:saturate-110 focus:outline-none focus:ring-4 focus:ring-cyan-400/20">
			Generar matrices
		</button>
	</div>
</section>
