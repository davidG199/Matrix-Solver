---
const operations = [
  {
    key: "home",
    short: "01",
    label: "Inicio",
    description: "Introduccion y acceso rapido al flujo principal.",
    title: "Matrix Solver",
  },
  {
    key: "suma",
    short: "+",
    label: "Suma",
    description: "Combina matrices con la misma dimension.",
    title: "Suma de matrices",
  },
  {
    key: "resta",
    short: "-",
    label: "Resta",
    description: "Resta matrices compatibles fila por fila.",
    title: "Resta de matrices",
  },
  {
    key: "multiplicacion",
    short: "x",
    label: "Multiplicacion",
    description: "Multiplica matrices segun sus dimensiones.",
    title: "Multiplicacion de matrices",
  },
  {
    key: "determinante",
    short: "det",
    label: "Determinante",
    description: "Calcula el valor determinante de una matriz cuadrada.",
    title: "Determinante",
  },
  {
    key: "inversa",
    short: "inv",
    label: "Inversa",
    description: "Obtiene la matriz inversa cuando existe.",
    title: "Matriz inversa",
  },
  {
    key: "cramer",
    short: "cr",
    label: "Cramer",
    description: "Resuelve sistemas lineales con la regla de Cramer.",
    title: "Regla de Cramer",
  },
  {
    key: "gauss",
    short: "G",
    label: "Gauss",
    description: "Reduce la matriz a forma escalonada.",
    title: "Eliminacion de Gauss",
  },
  {
    key: "gauss-jordan",
    short: "GJ",
    label: "Gauss-Jordan",
    description: "Lleva la matriz a forma escalonada reducida.",
    title: "Gauss-Jordan Elimination",
  },
];

const { activeKey  } = Astro.props;
---

<aside
  class="flex h-auto flex-col gap-4 overflow-y-auto border-b border-white/10 bg-slate-950/40 py-6 shadow-[inset_-1px_0_0_rgba(255,255,255,0.05)] backdrop-blur-2xl lg:sticky lg:top-0 lg:h-screen lg:border-b-0 lg:border-r lg:border-white/10"
>
  <div class="flex items-center justify-center gap-3 py-2">
    <div class="min-w-0 text-center pb-3">
      <p class="truncate text-lg font-bold tracking-tighter text-white">
        Matrix Solver
      </p>
    </div>
  </div>

  <div class="px-4">
    <nav
      class="flex flex-col gap-2 border-t border-white/10 pt-4"
      aria-label="Operaciones de matrices"
    >
      {
        operations.map((operation) => (
          <button
            type="button"
            class={`flex w-full items-center gap-3 rounded-2xl border text-left transition duration-200 cursor-pointer  hover:bg-white/10 hover:text-white hover:shadow-[0_10px_22px_rgba(0,0,0,0.22)] ${operation.key === activeKey ? "border-cyan-400/20 bg-linear-to-br from-cyan-400/10 to-indigo-500/10 text-white" : "border-transparent bg-transparent text-slate-400"}`}
            data-operation={operation.key}
            aria-pressed={operation.key === activeKey ? "true" : "false"}
          >
            {/* <span
              data-operation-icon
              class={
                operation.key === activeKey
                  ? "grid h-2 w-10 shrink-0 place-items-center rounded-2xl bg-gradient-to-br from-cyan-400 to-indigo-600 text-xs font-bold text-slate-950 shadow-[0_12px_24px_rgba(56,189,248,0.22)]"
                  : "grid h-10 w-10 shrink-0 place-items-center rounded-2xl border border-white/10 bg-white/5 text-xs font-bold text-cyan-200"
              }
            >
              {operation.short}
            </span> */}
            <span class="min-w-0">
              <strong class="block text-sm font-semibold text-inherit">
                {operation.label}
              </strong>
            </span>
          </button>
        ))
      }
    </nav>
  </div>
</aside>
