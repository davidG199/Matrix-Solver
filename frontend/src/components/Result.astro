<section data-result-shell class="flex flex-col gap-4 rounded-4xl border border-white/10 bg-white/5 p-5 shadow-[0_28px_80px_rgba(0,0,0,0.32)] backdrop-blur-2xl">
	<div class="flex items-start justify-between gap-4">
		<div>
			<p class="text-[0.72rem] font-bold uppercase tracking-[0.16em] text-slate-400">Resultado</p>
			<h3 class="display-font mt-1 text-[1.12rem] font-semibold tracking-tighter text-white">Salida final</h3>
		</div>
		<span data-validation-chip class="inline-flex items-center justify-center rounded-full bg-slate-500/10 px-3 py-1 text-[0.72rem] font-bold uppercase tracking-[0.12em] text-slate-300">Esperando operacion</span>
	</div>

	<p data-validation-message class="text-sm leading-6 text-slate-300">Selecciona una operacion para ver las reglas que deben cumplirse antes de generar la grilla.</p>

	<div class="relative overflow-hidden rounded-[1.4rem] border border-white/10 bg-[radial-gradient(circle_at_20%_20%,rgba(56,189,248,0.10),transparent_24%),radial-gradient(circle_at_82%_8%,rgba(99,102,241,0.12),transparent_28%),linear-gradient(180deg,rgba(15,23,42,0.84),rgba(15,23,42,0.58))] px-5 py-4 shadow-[inset_0_1px_0_rgba(255,255,255,0.04)]">
		<div class="grid grid-cols-4 gap-x-3 gap-y-2" aria-label="Vista previa de resultado">
			<span class="grid h-10 place-items-center rounded-xl border border-white/10 bg-white/5 font-semibold text-white/80">1</span>
			<span class="grid h-10 place-items-center rounded-xl border border-white/10 bg-white/5 font-semibold text-white/80">0</span>
			<span class="grid h-10 place-items-center rounded-xl border border-white/10 bg-white/5 font-semibold text-white/80">0</span>
			<span class="grid h-10 place-items-center rounded-xl border border-white/10 bg-white/5 font-semibold text-white/80">2</span>
			<span class="grid h-10 place-items-center rounded-xl border border-white/10 bg-white/5 font-semibold text-white/80">0</span>
			<span class="grid h-10 place-items-center rounded-xl border border-white/10 bg-white/5 font-semibold text-white/80">1</span>
			<span class="grid h-10 place-items-center rounded-xl border border-white/10 bg-white/5 font-semibold text-white/80">0</span>
			<span class="grid h-10 place-items-center rounded-xl border border-white/10 bg-white/5 font-semibold text-white/80">3</span>
			<span class="grid h-10 place-items-center rounded-xl border border-white/10 bg-white/5 font-semibold text-white/80">0</span>
			<span class="grid h-10 place-items-center rounded-xl border border-white/10 bg-white/5 font-semibold text-white/80">0</span>
			<span class="grid h-10 place-items-center rounded-xl border border-white/10 bg-white/5 font-semibold text-white/80">1</span>
			<span class="grid h-10 place-items-center rounded-xl border border-white/10 bg-white/5 font-semibold text-white/80">-1</span>
		</div>
	</div>

	<div class="grid gap-2 rounded-[1.4rem] border border-white/10 bg-white/5 p-4 text-sm text-slate-300">
		<p class="text-[0.72rem] font-bold uppercase tracking-[0.16em] text-slate-400">Resumen</p>
		<ul class="grid gap-2" data-result-summary>
			<li class="flex items-center justify-between rounded-xl border border-white/10 bg-slate-950/50 px-4 py-3">
				<span class="text-slate-400">Matriz A</span>
				<strong class="text-cyan-200">Pendiente</strong>
			</li>
			<li class="flex items-center justify-between rounded-xl border border-white/10 bg-slate-950/50 px-4 py-3">
				<span class="text-slate-400">Matriz B</span>
				<strong class="text-cyan-200">Pendiente</strong>
			</li>
		</ul>
	</div>
</section>
