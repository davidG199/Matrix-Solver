---
---

<section class="flex flex-col gap-4">
	<article class="rounded-3xl border border-slate-200/70 bg-white/80 p-5 shadow-[0_28px_65px_rgba(15,23,42,0.12)] backdrop-blur-xl">
		<div class="mb-4 flex items-start justify-between gap-4">
			<div>
				<p class="mb-1 text-[0.72rem] font-bold uppercase tracking-[0.16em] text-slate-500">Procedimiento</p>
				<h3 class="display-font text-[1.12rem] font-semibold tracking-[-0.03em]">Paso a paso</h3>
			</div>
			<span class="inline-flex items-center justify-center rounded-full bg-slate-500/10 px-3 py-1 text-[0.72rem] font-bold uppercase tracking-[0.12em] text-slate-600">Proximamente</span>
		</div>

		<div class="rounded-2xl border border-dashed border-slate-300/70 bg-white/70 p-4 text-sm leading-6 text-slate-500">
			<strong class="block text-slate-900">Esta zona queda reservada para las transformaciones de filas.</strong>
			<p class="mt-2">
				Cuando conectes el backend, aqui podras mostrar pivotes, operaciones elementales y notas por cada paso.
			</p>
		</div>
	</article>

	<article class="rounded-3xl border border-slate-200/70 bg-linear-to-b from-slate-50/95 to-indigo-50/80 p-5 shadow-[0_28px_65px_rgba(15,23,42,0.12)] backdrop-blur-xl">
		<div class="mb-4 flex items-start justify-between gap-4">
			<div>
				<p class="mb-1 text-[0.72rem] font-bold uppercase tracking-[0.16em] text-slate-500">Resultado</p>
				<h3 class="display-font text-[1.12rem] font-semibold tracking-[-0.03em]">Salida final</h3>
			</div>
			<span class="inline-flex items-center justify-center rounded-full bg-emerald-500/10 px-3 py-1 text-[0.72rem] font-bold uppercase tracking-[0.12em] text-emerald-700">Vista previa</span>
		</div>

		<div class="grid gap-4">
			<div class="relative overflow-hidden rounded-[1.2rem] border border-slate-200/70 bg-linear-to-b from-slate-50 to-indigo-50/70 px-6 py-5">
				<div class="grid grid-cols-4 gap-x-3 gap-y-2" aria-label="Resultado de ejemplo">
					<span class="grid h-10 place-items-center rounded-xl border border-slate-300/70 bg-white/90 font-semibold text-slate-900">1</span>
					<span class="grid h-10 place-items-center rounded-xl border border-slate-300/70 bg-white/90 font-semibold text-slate-900">0</span>
					<span class="grid h-10 place-items-center rounded-xl border border-slate-300/70 bg-white/90 font-semibold text-slate-900">0</span>
					<span class="grid h-10 place-items-center rounded-xl border border-slate-300/70 bg-white/90 font-semibold text-slate-900">2</span>
					<span class="grid h-10 place-items-center rounded-xl border border-slate-300/70 bg-white/90 font-semibold text-slate-900">0</span>
					<span class="grid h-10 place-items-center rounded-xl border border-slate-300/70 bg-white/90 font-semibold text-slate-900">1</span>
					<span class="grid h-10 place-items-center rounded-xl border border-slate-300/70 bg-white/90 font-semibold text-slate-900">0</span>
					<span class="grid h-10 place-items-center rounded-xl border border-slate-300/70 bg-white/90 font-semibold text-slate-900">3</span>
					<span class="grid h-10 place-items-center rounded-xl border border-slate-300/70 bg-white/90 font-semibold text-slate-900">0</span>
					<span class="grid h-10 place-items-center rounded-xl border border-slate-300/70 bg-white/90 font-semibold text-slate-900">0</span>
					<span class="grid h-10 place-items-center rounded-xl border border-slate-300/70 bg-white/90 font-semibold text-slate-900">1</span>
					<span class="grid h-10 place-items-center rounded-xl border border-slate-300/70 bg-white/90 font-semibold text-slate-900">-1</span>
				</div>
			</div>

			<div class="flex flex-col gap-3">
				<p class="text-[0.82rem] font-bold uppercase tracking-[0.14em] text-slate-500">Variables</p>
				<ul class="grid gap-2">
					<li class="flex items-center justify-between gap-4 rounded-xl border border-slate-300/40 bg-white/85 px-4 py-3">
						<span class="font-semibold text-slate-500">x1</span>
						<strong class="text-blue-700">= 2</strong>
					</li>
					<li class="flex items-center justify-between gap-4 rounded-xl border border-slate-300/40 bg-white/85 px-4 py-3">
						<span class="font-semibold text-slate-500">x2</span>
						<strong class="text-blue-700">= 3</strong>
					</li>
					<li class="flex items-center justify-between gap-4 rounded-xl border border-slate-300/40 bg-white/85 px-4 py-3">
						<span class="font-semibold text-slate-500">x3</span>
						<strong class="text-blue-700">= -1</strong>
					</li>
				</ul>
			</div>
		</div>
	</article>
</section>
