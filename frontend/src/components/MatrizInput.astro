<section data-matrix-shell class="hidden flex flex-col gap-4 rounded-4xl border border-white/10 bg-white/5 p-5 shadow-[0_28px_80px_rgba(0,0,0,0.32)] backdrop-blur-2xl">
	<div class="flex items-start justify-between gap-4">
		<div>
			<p class="text-[0.72rem] font-bold uppercase tracking-[0.16em] text-slate-400">Ingreso</p>
			<h2 data-matrix-title class="display-font mt-1 text-[1.12rem] font-semibold tracking-tighter text-white">Matrices necesarias</h2>
		</div>
		<span data-matrix-summary class="inline-flex whitespace-nowrap items-center justify-center rounded-full border border-white/10 bg-white/5 px-3 py-1 text-[0.72rem] font-bold uppercase tracking-[0.14em] text-cyan-200">0 matrices</span>
	</div>

	<div data-matrix-cards class="grid gap-4"></div>

	<div class="flex flex-col gap-3 border-t border-white/10 pt-4 sm:flex-row sm:items-center sm:justify-between">
		<p class="text-sm leading-6 text-slate-400">Las grillas se renderizan solo cuando la estructura cumple la restriccion de la operacion.</p>
		<button data-calculate-matrices type="button" class="rounded-full bg-linear-to-r from-emerald-400 to-emerald-500 px-5 py-3 text-sm font-semibold text-slate-950 shadow-[0_14px_30px_rgba(16,185,129,0.2)] transition hover:-translate-y-px hover:saturate-110 focus:outline-none focus:ring-4 focus:ring-emerald-400/20">
			Calcular
		</button>
	</div>
</section>
