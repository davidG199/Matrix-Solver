---
import { AstroFont } from 'astro-font';

const { title = 'Matrix Solver' } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content="Aplicacion academica para resolver operaciones con matrices paso a paso." />
		<AstroFont
			config={[
				{
					name: 'Space Grotesk',
					src: [],
					googleFontsURL: 'https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&display=swap',
					preload: true,
					display: 'swap',
					selector: 'h1, h2, h3, h4, .display-font, .brand-title',
					fallback: 'sans-serif',
				},
				{
					name: 'Inter',
					src: [],
					googleFontsURL: 'https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap',
					preload: true,
					display: 'swap',
					selector: 'body',
					fallback: 'sans-serif',
				},
			]}
		/>
		<title>{title}</title>
	</head>
	<body class="grid min-h-screen grid-cols-1 overflow-x-hidden bg-slate-950 text-slate-100 antialiased lg:grid-cols-[284px_minmax(0,1fr)]">
		<slot name="aside" />
		<slot name="main" />
	</body>
</html>
